{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/checkout/create-session.ts": { "maxDuration": 30 },
    "api/checkout/session.ts": { "maxDuration": 30 },
    "api/webhooks/stripe.ts": { "maxDuration": 30 },
    "api/health.ts": { "maxDuration": 10 },
    "api/ping.ts": { "maxDuration": 10 },
    "api/checkout/test-stripe.ts": { "maxDuration": 10 },
    "api/checkout/test-lib-env.ts": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
